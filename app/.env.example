# Freeela - Environment Variables

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Obtenha essas credenciais em: https://app.supabase.com/project/_/settings/api

# URL do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) - pode ser exposta no frontend
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave de serviço (service role key) - NÃO EXPONHA no frontend
# Usar apenas em backend/scripts
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ============================================
# GEMINI API (IA)
# ============================================
# Para gerar documentos com IA
# Obtenha em: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=sua-gemini-api-key-aqui

# ============================================
# ELECTRON / DESKTOP
# ============================================
# Configurações específicas para app desktop
VITE_APP_NAME=Freeela
VITE_APP_VERSION=1.0.0

# ============================================
# DEVELOPMENT
# ============================================
# Porta do servidor de desenvolvimento
VITE_PORT=5173

# Ambiente (development | production)
NODE_ENV=development

# ============================================
# OPCIONAL: INTEGRATIONS
# ============================================

# Stripe (Pagamentos)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# AWS S3 (Storage de arquivos)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=freeela-documents

# SendGrid (Emails transacionais)
# SENDGRID_API_KEY=...
# SENDGRID_FROM_EMAIL=noreply@freeela.com
